# Quiz Engine - Environment Configuration Template
# Copy this file to .env and update with your actual configuration values

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Database Configuration (MySQL)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password_here
DB_NAME=quiz_db

# ============================================================
# AI Integration - ASI:One API
# ============================================================
# Get your API key from https://asi1.ai
ASI_API_KEY=your_asi1_api_key_here

# ============================================================
# Redis Configuration (Optional)
# ============================================================
# Leave empty to use in-memory fallback for sessions/rate limiting
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=

# ============================================================
# Security
# ============================================================
# Generate a strong random string for production
# Example: openssl rand -hex 32
CERT_TOKEN_SECRET=change-me-in-production

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins for API requests
# Leave empty to allow all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# Reverse Proxy Configuration
# ============================================================
# Set to 'true' if running behind a proxy (nginx, Cloudflare, AWS ALB, etc.)
TRUST_PROXY=false

